{
  "name": "soundcheck-pocket",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "main": "index.ts",
  "scripts": {
    "preinstall": "node scripts/ensure-pnpm.mjs",
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "security:audit": "node scripts/security/audit-supply-chain.mjs",
    "security:deps-audit": "pnpm audit --audit-level high",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "pnpm": {
    "overrides": {
      "axios": "1.14.0"
    }
  },
  "dependencies": {
    "expo": "~55.0.24",
    "expo-audio": "~55.0.14",
    "expo-localization": "^55.0.14",
    "expo-status-bar": "~55.0.6",
    "i18next": "^26.2.0",
    "react": "19.2.0",
    "react-i18next": "^17.0.8",
    "react-native": "0.83.6",
    "react-native-safe-area-context": "^5.7.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~5.9.2",
    "vitest": "^3.2.4"
  }
}
